# EasyFold environment variables.
# Copy to `.env.local` (gitignored) and fill in if you need to override defaults.
# Real values must never be committed.

# ── Backend ────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins for the FastAPI backend.
# Defaults to `http://localhost:3000` (the Next.js dev default) so the
# Quickstart's local stack works without setting this variable. Override
# when Next falls back to 3001 (port 3000 busy):
#   EASYFOLD_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Or for production, set to your real frontend URL(s):
#   EASYFOLD_CORS_ORIGINS=https://your-frontend.example.com
EASYFOLD_CORS_ORIGINS=http://localhost:3000

# When set to "true" / "1" / "yes", upstream error handlers (Modal / external
# API failures) return a generic `{"detail": "upstream error"}` instead of
# echoing the underlying exception message. The verbose detail still goes to
# server logs. Recommended when serving the backend to untrusted users.
EASYFOLD_GENERIC_ERRORS=

# Per-IP rate limit on `POST /api/v1/jobs`, expressed as the integer
# count-per-hour. Empty / unset disables rate limiting entirely (suitable
# for single-user self-host). Requires the optional `slowapi` dependency
# — install with `uv sync --extra ratelimit`. See SECURITY.md for the
# full "if you expose this backend publicly" hardening checklist.
EASYFOLD_RATE_LIMIT_JOBS_PER_IP_PER_HOUR=

# ── Frontend ───────────────────────────────────────────────────────────

# Where the frontend looks for the FastAPI backend. Override in production
# when frontend and backend are on different hosts.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Not env vars (informational) ───────────────────────────────────────

# - The Anthropic API key for the Interpret panel is bring-your-own and
#   entered directly in the browser UI (BYOK). It's never stored, never
#   sent to the EasyFold backend, and there's no env var to configure.
#
# - Modal credentials live in ~/.modal.toml after running `uv run modal setup`
#   (one-time, opens a browser). The Modal SDK reads that file directly;
#   we don't surface MODAL_TOKEN_ID / MODAL_TOKEN_SECRET as env vars.
