# EasyFold environment variables.
# Copy to `.env.local` (gitignored) and fill in if you need to override defaults.
# Real values must never be committed.

# ── Backend ────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins for the FastAPI backend.
# Defaults to "http://localhost:3000,http://localhost:3001" (covers Next.js
# dev both on its primary port and the 3001 fallback when 3000 is busy).
# Override only when serving the backend at a non-default origin.
EASYFOLD_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Frontend ───────────────────────────────────────────────────────────

# Where the frontend looks for the FastAPI backend. Override in production
# when frontend and backend are on different hosts.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Not env vars (informational) ───────────────────────────────────────

# - The Anthropic API key for the Interpret panel is bring-your-own and
#   entered directly in the browser UI (BYOK). It's never stored, never
#   sent to the EasyFold backend, and there's no env var to configure.
#
# - Modal credentials live in ~/.modal.toml after running `uv run modal setup`
#   (one-time, opens a browser). The Modal SDK reads that file directly;
#   we don't surface MODAL_TOKEN_ID / MODAL_TOKEN_SECRET as env vars.
