# Anthropic Claude API — used for natural-language result interpretation.
# Users supply their own key (BYOK); never commit a real value.
ANTHROPIC_API_KEY=

# Modal credentials — required only when deploying the production stack
# to your own Modal account. Get these from https://modal.com/settings/tokens.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Frontend → backend base URL. Override in production deployments.
NEXT_PUBLIC_API_URL=http://localhost:8000
